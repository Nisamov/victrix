#!/bin/bash

ssp_files="/usr/local/sbin/ssp_files"
ssp_service="/etc/systemd/system/ssp.service"
ssp_file="/usr/local/sbin/ssp"
etc_ssp="/etc/ssp"
config_file="/etc/ssp.conf"
main_service=/usr/sbin/ssp_files""

uninstall() {
    read -rp "Are you sure you want to uninstall? (y/n): " confirmation
    if [[ "$confirmation" =~ ^[Yy]$ ]]; then
        echo "Uninstalling..."
        sudo systemctl stop ssp
        sudo systemctl disable ssp
        sudo rm -f "$ssp_service"
        sudo rm -rf "$ssp_files" "$ssp_file" "$etc_ssp"
        # Verification
        if [[ ! -e "$ssp_service" && ! -d "$ssp_files" && ! -f "$ssp_file" && ! -d "$etc_ssp" ]]; then
            echo "Uninstallation successfull."
        else
            echo "Error: Some of the files/dirs couldn't be removed."
            ls -ld "$ssp_service" "$ssp_files" "$ssp_file" "$etc_ssp" 2>/dev/null
            read -rp "Do you want to retry? (y/n): " retry
            if [[ "$retry" =~ ^[Yy]$ ]]; then
                uninstall
            else
                exit 1 # Exit by cancellation
            fi
        fi
    else
        echo "Uninstallation cancelled."
        exit 1 # Exit by cancellation
    fi
}
case "$1" in
    -h|--help)
        echo "Opciones disponibles:"
        echo "  -h, --help       Show help"
        echo "  -v, --version    Show version"
        echo "  -c, --config     Edit configuration file"
        echo "  -l  --logs       Open logs folder"
        echo "  -u, --uninstall  Desinstala el servicio y archivos relacionados"
        ;;
    -v|--version)
        echo "V2.0.0"
        ;;
    -c|--config)
        sudo nano "$config_file"
        #vim "$config_file"
        ;;
    -e|--execute)
        #Ejecucion manual de servicio
        python "$ssp_files/service.py"
        ;;
    -l|--logs)
        cd "/var/log/ssp/" && ll
        ;;
    -u|--uninstall)
        uninstall
        ;;
    *)
        echo "Error: $1"
        exit 1 # Exit by cancellation
        ;;
esac