#!/bin/bash

# Rutas corregidas para que coincidan con el paquete
config_file="/etc/victrix/victrix.conf"
LOG_DIR="/var/log/victrix"
ROJO='\033[0;31m'
NC='\033[0m' # Sin color
AMARILLO='\033[1;33m'

# Ejecutar comando como root si no estamos ya como root
run_as_root() {
    if [ "$(id -u)" -eq 0 ]; then
        "$@"
    else
        sudo "$@"
    fi
}

uninstall() {
    read -rp "Estás seguro de querer desinstalar el servicio? (y/n): " confirmation
    if [[ "$confirmation" =~ ^[Yy]$ ]]; then
        echo -e "${ROJO}Se ha iniciado la desinstalación de Victrix${NC}"
        # Parar y deshabilitar el servicio (usar nombre completo .service)
        run_as_root systemctl stop victrix.service || true
        run_as_root systemctl disable victrix.service || true
        # Quitar el paquete
        run_as_root dpkg -r victrix || {
            echo "Error: no se pudo desinstalar el paquete victrix con dpkg."
            return 1
        }
        echo "Desinstalación iniciada. Revisa prerm para limpieza adicional."
    else
        echo -e "${ROJO}Desinstalación cancelada.${NC}"
        return 1
    fi
}

show_help() {
    cat <<EOF
Opciones disponibles:
  -h, --help       Mostrar ayuda
  -v, --version    Mostrar versión
  -c, --config     Editar el fichero de configuración (/etc/ssp/ssp.conf)
  -l, --logs       Listar el directorio de logs ($LOG_DIR)
  -u, --uninstall  Desinstala el servicio y archivos relacionados
  man               Abre el manual del servicio (man ssp) si existe
EOF
}

# Si no se pasa argumento, mostrar ayuda
if [ "$#" -eq 0 ]; then
    show_help
    exit 0
fi

case "$1" in
    -h|--help)
        show_help
        ;;
    -v|--version)
        echo "V0.0.0"
        ;;
    -c|--config)
        if [ -f "$config_file" ]; then
            run_as_root ${EDITOR:-nano} "$config_file"
        else
            echo "Fichero de configuracion no encontrado: $config_file"
            exit 1
        fi
        ;;
    -l|--logs)
        if [ -d "$LOG_DIR" ]; then
            ls -l "$LOG_DIR"
        else
            echo "No se encontró el directorio de logs: $LOG_DIR"
            echo "Intenta crear el directorio con sudo mkdir -p $LOG_DIR o revisa la configuración."
            exit 1
        fi
        ;;
    -u|--uninstall)
        uninstall
        ;;
    man)
        if man victrix >/dev/null 2>&1; then
            man victrix
        else
            echo "Manual (man) no encontrado para 'victrix'."
            exit 1
        fi
        ;;
    *)
        echo -e "Error: ${ROJO}'$1'${NC} - Carácter no válido"
        echo -e "Prueba ${AMARILLO}'victrix --help'${NC} o ${AMARILLO}'man victrix'${NC}."
        exit 1
        ;;
esac