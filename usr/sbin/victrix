#!/bin/bash

# Rutas corregidas para que coincidan con el paquete
config_file="/etc/victrix/victrix.conf"
LOG_DIR="/var/log/victrix"
ROJO='\033[0;31m'
NC='\033[0m' # Sin color
AMARILLO='\033[1;33m'

# Ejecutar comando como root si no estamos ya como root
run_as_root() {
    if [ "$(id -u)" -eq 0 ]; then
        "$@"
    else
        sudo "$@"
    fi
}

uninstall() {
    read -rp "Estás seguro de querer desinstalar el servicio? (y/n): " confirmation
    if [[ "$confirmation" =~ ^[Yy]$ ]]; then
        echo -e "${ROJO}Se ha iniciado la desinstalación de Victrix${NC}"
        # Parar y deshabilitar el servicio (usar nombre completo .service)
        run_as_root systemctl stop victrix.service || true
        run_as_root systemctl disable victrix.service || true
        # Quitar el paquete
        run_as_root dpkg -r victrix || {
            echo "Error: no se pudo desinstalar el paquete victrix con dpkg."
            return 1
        }
        echo "Desinstalación iniciada. Revisa prerm para limpieza adicional."
    else
        echo -e "${ROJO}Desinstalación cancelada.${NC}"
        return 1
    fi
}

show_help() {
    cat <<EOF
Opciones disponibles:
  -h, --help            Mostrar esta ayuda
  -hx,--help-extend     Mostrar ayuda extendida
  -v, --version         Mostrar versión
  -c, --config          Editar el fichero de configuración (/etc/victrix/victrix.conf)
  -l, --logs            Listar el directorio de logs ($LOG_DIR)
  -u, --uninstall       Desinstala el servicio y archivos relacionados
  -g, --git             Descargar repositorio de github
    -source $3          Descargar desde el repositorio del autor
    -nown $3            Descargar desde repositorio externo
  man                   Abre el manual del servicio (man victrix) si existe
EOF
}

show_help_extend() {
    cat <<EOF
Opciones disponibles:
  -h, --help      >     Mostrar esta ayuda
    (victrix -h || victrix --help)
  -hx,--help-extend     Mostrar ayuda extendida
    (victrix -hx || victrix --help-extend)
  -v, --version   >     Mostrar versión
    (victrix -v || victrix --version)
  -c, --config    >     Editar el fichero de configuración (/etc/victrix/victrix.conf)
    (victrix -c || victrix --config)
  -l, --logs      >     Listar el directorio de logs ($LOG_DIR)
    (victrix -l || victrix --logs)
  -u, --uninstall >     Desinstala el servicio y archivos relacionados
    (victrix -u || victrix --uninstall)
  -g, --git       >     Descargar repositorio de github
    -source repo_name       > Descargar desde el repositorio del autor
        Ejemplo: 'victrix -g -source LinuxCommands'
    -nown author/repo_name  > Descargar desde repositorio externo
        Ejemplo: 'victrix -g -nown user/radrepo'
  -pop, --popcat  >     Reproducir popcat en ascii
    (victrix -pop || victrix -popcat)
  man             >     Abre el manual
    (victrix man || man victrix)
EOF
}

# Si no se pasa argumento, mostrar ayuda
if [ "$#" -eq 0 ]; then
    show_help
    exit 0
fi

case "$1" in
    -h|--help)
        show_help
        ;;
    -hx|--help-extend)
        show_help_extend
        ;;
    -v|--version)
        echo "V0.0.0"
        ;;
    -c|--config)
        if [ -f "$config_file" ]; then
            run_as_root ${EDITOR:-nano} "$config_file"
        else
            echo "Fichero de configuracion no encontrado: $config_file"
            exit 1
        fi
        ;;
    -l|--logs)
        if [ -d "$LOG_DIR" ]; then
            ls -l "$LOG_DIR"
        else
            echo "No se encontró el directorio de logs: $LOG_DIR"
            echo "Intenta crear el directorio con sudo mkdir -p $LOG_DIR o revisa la configuración."
            exit 1
        fi
        ;;
    -u|--uninstall)
        uninstall
        ;;
    -g|--git)
        repodir="/home/$USER/Documents/repos"
        if [ ! -d "/home/$USER/Documents" ]; then
            echo "Creando directorio de documentos para el usuario: /home/$USER/Documents..."
            mkdir -p "/home/$USER/Documents"
        else
            if [ ! -d "$repodir" ]; then
                echo "Creando directorio de repositorios: '$repodir'..."
                mkdir -p "$repodir"
                if [ -d "$repodir" ]; then
                    echo "Directorio de repositorios creado correctamente."
                else
                    echo "Error: no se ha podido crear el directorio de repositorios."
                    exit 1
                fi
            fi
        fi
        if [ "$2" == "-source" ] && [ -n "$3" ]; then
            echo "Descargando desde el repositorio del autor: $3"
            git clone "https://github.com/Nisamov/$3" "$repodir/Nisamov/$3"
        elif [ "$2" == "-nown" ] && [ -n "$3" ]; then
            if [ ! -d "$repodir/External" ]; then
                mkdir -p "$repodir/External"
                if [ -d "$repodir/External" ]; then
                    echo "Directorio '$repodir/External' creado."
                else
                    echo "Ha ocurrido un problema durante la creacion de '$repodir/External'"
                    exit 1
                fi
            fi
            echo "Descargando desde repositorio externo: $3"
            git clone "https://github.com/$3" "$repodir/External/$3"
        else
            echo "Error: opción de git no válida. Usa '-source repo_name' o '-nown author/repo_name'."
            exit 1
        fi
        ;;
    -pop|--popcat)
        while true;
        do
            clear
            # Estado 1
            cat "/usr/sbin/victrix_files/motion/popcat/nf.txt"
            clear
            # Estado 2
            cat "/usr/sbin/victrix_files/motion/popcat/ns.txt"
        done  
        ;;
    man)
        if man victrix >/dev/null 2>&1; then
            man victrix
        else
            echo "Manual no encontrado."
            echo "Fuente: /share/man/man8/victrix.8"
            exit 1
        fi
        ;;
    *)
        echo -e "Error: ${ROJO}'$1'${NC} - Carácter no válido"
        echo -e "Prueba ${AMARILLO}'victrix --help'${NC} o ${AMARILLO}'man victrix'${NC}."
        exit 1
        ;;
esac