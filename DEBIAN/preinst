#!/bin/bash
set -euo pipefail

echo "Running preinst for ssp"

if command -v python3 >/dev/null 2>&1; then
    echo "Python3 found: $(python3 --version 2>&1)"
else
    echo "Python3 not found."
    if [ "${SSP_ALLOW_INSTALL_PYTHON:-no}" = "yes" ]; then
        if [ "$(id -u)" -ne 0 ]; then
            echo "ERROR: Not running as root; cannot install python3. Please install python3 manually or rerun as root."
            exit 1
        fi
        if command -v apt-get >/dev/null 2>&1; then
            echo "Installing python3 non-interactively using apt-get..."
            export DEBIAN_FRONTEND=noninteractive
            apt-get update -y || { echo "apt-get update failed"; exit 1; }
            apt-get install -y python3 || { echo "apt-get install python3 failed"; exit 1; }
            echo "python3 installed."
        else
            echo "ERROR: apt-get not available. Please install python3 manually."
            exit 1
        fi
    else
        echo "Python3 is required. To allow automatic installation during package install set SSP_ALLOW_INSTALL_PYTHON=yes in the environment, or install python3 manually before installing this package."
        exit 1
    fi
fi

LOG_DIR="/var/log/ssp"
if [ ! -d "$LOG_DIR" ]; then
    echo "Creating log directory: $LOG_DIR"
    install -d -m 0755 "$LOG_DIR"
else
    echo "Log directory exists: $LOG_DIR"
fi


chown root:root "$LOG_DIR" || true
chmod 0755 "$LOG_DIR" || true

exit 0
