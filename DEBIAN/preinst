#!/bin/bash
set -euo pipefail

echo "Ejecutando preinst para victrix"

# Creacion de usuario y grupo para el servicio
if ! id -u victrix >/dev/null 2>&1; then
    echo "Creando usuario y grupo 'victrix'."
    useradd --system --no-create-home --shell /usr/sbin/nologin victrix || { echo "Error al crear el usuario victrix."; exit 1; }
else
    echo "Usuario 'victrix' ya existe."
fi

# Creacion directorio de logs
LOG_DIR="/var/log/victrix"
if [ ! -d "$LOG_DIR" ]; then
    echo "Creating log directory: $LOG_DIR"
    install -d -m 0755 "$LOG_DIR"
else
    echo "Log directory exists: $LOG_DIR"
fi

chown root:root "$LOG_DIR" || true
chmod 0755 "$LOG_DIR" || true

exit 0